<?xml version="1.0"?>
<Container version="2">
  <Name>H15-Hub</Name>
  <Repository>ghcr.io/hoktaar/h15-hub:latest</Repository>
  <Registry>https://github.com/hoktaar/H15-Hub/pkgs/container/h15-hub</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/hoktaar/H15-Hub</Support>
  <Project>https://github.com/hoktaar/H15-Hub</Project>
  <Overview>Lokaler Integrations-Hub für den Hebewerk e.V. Makerspace. Verbindet Home Assistant, Bambu 3D-Drucker, Lasercutter, Labeldrucker und Netzwerkdrucker in einem einheitlichen Echtzeit-Dashboard.</Overview>
  <Category>HomeAutomation: Tools:</Category>
  <WebUI>http://[IP]:[PORT:8031]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/hoktaar/H15-Hub/main/unraid/h15hub.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/hoktaar/H15-Hub/main/unraid/icon.png</Icon>
  <ExtraParams></ExtraParams>
  <PostArgs/>
  <CPUset/>
  <DonateText/>
  <DonateLink/>
  <Requires/>

  <!-- Daten-Verzeichnis -->
  <Config Name="AppData" Target="/app/data" Default="/mnt/user/appdata/h15hub/data" Mode="rw" Description="Persistente Daten (SQLite-Datenbank)" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/h15hub/data</Config>

  <!-- Konfigurationsverzeichnis (enthält config.yaml) -->
  <Config Name="Config Dir" Target="/app/config" Default="/mnt/user/appdata/h15hub/config" Mode="rw" Description="Verzeichnis mit config.yaml (Geräte-IPs und API-Keys). Beim ersten Start wird automatisch eine Beispiel-Konfiguration erstellt." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/h15hub/config</Config>

  <!-- Port -->
  <Config Name="WebUI Port" Target="8000" Default="8031" Mode="tcp" Description="Port für das Web-Dashboard" Type="Port" Display="always" Required="true" Mask="false">8031</Config>

  <!-- Umgebungsvariablen -->
  <Config Name="Config Path" Target="H15HUB_CONFIG" Default="/app/config/config.yaml" Description="Pfad zur config.yaml im Container (nicht ändern)" Type="Variable" Display="advanced" Required="true" Mask="false">/app/config/config.yaml</Config>

  <Config Name="Database URL" Target="H15HUB_DB_URL" Default="sqlite+aiosqlite:////app/data/h15hub.db" Description="SQLite Datenbankpfad" Type="Variable" Display="advanced" Required="false" Mask="false">sqlite+aiosqlite:////app/data/h15hub.db</Config>

  <Config Name="Log Level" Target="LOG_LEVEL" Default="INFO" Description="Log-Level: DEBUG, INFO, WARNING, ERROR" Type="Variable" Display="advanced" Required="false" Mask="false">INFO</Config>

</Container>
